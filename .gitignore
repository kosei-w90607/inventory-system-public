# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Node / Vite / Tauri
node_modules/
dist/
dist-ssr/

# Vitest install 時の package*.json backup (Phase 1 7-7a、rollback path 用)
package.json.bak
package-lock.json.bak

# TanStack Router auto-generated route tree (adopted 2026-04-20, ADR-001)
src/routeTree.gen.ts

# tauri-specta auto-generated TS bindings — vendor-in 運用（2026-04-21, ADR-002 運用更新）
# 生成物だが repo に commit して CI frontend job の Rust 依存を避ける。
# Rust 側変更時の drift は CI rust job の drift check step (cargo run --bin generate_bindings + git diff --exit-code) で検知する。
# src/lib/bindings.ts  # ← 旧: gitignore 対象。現運用では vendor-in するため無効化

*.local
.DS_Store

src-tauri/target/

# Local SQLite DB generated by native/dev seed runs. Product/store data must not be committed.
src-tauri/*.db

# Environment
# Vite env 読み込み順序: .env -> .env.{mode} -> .env.{mode}.local -> .env.local
# git commit するのは .env.example / .env.{development,test,production} のみ。
# 個人機固有上書きは .env / .env.local / .env.*.local で、これらは全て gitignore。
# 詳細: docs/UI_TECH_STACK.md §6.9 環境変数設計
.env
.env.local
.env.*.local
*.local

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# OS
.DS_Store
Thumbs.db

# Docker
cargo-cache/

# Claude Code runtime state
**/.claude/logs/
**/.claude/state/

# Codex local-only overrides
**/.codex/*.local.rules
**/.codex/*.local.toml
**/.codex/hooks.json
**/.codex/hooks/
**/.codex/logs/
**/.codex/state/

# レジ出力データ等の参考ファイル（ローカル保持、git管理外）
# 運用意図: Z004やPLUのレジ出力は実店舗固有データのため、リポジトリには含めない。
# E-4仕様根拠はオンライン調査（カシオCV17マニュアル）に基づいており、
# docs/ARCHITECTURE.md および docs/function-design/25-io-plu-formatter.md に記録済み。
docs/reference/
.local/

# 2026-05-15 追加: 実 CSV 検証データ (Phase 2 UI-07 検証フェーズ)
# user 運用で docs/research/real-csv/ を実機 CSV 配置場所として採用。
# 経営情報 (売価/原価/取引明細) を含むため git 管理外。
# .gitkeep / README.md のみ管理して構造を保証する。
docs/research/real-csv/*
!docs/research/real-csv/.gitkeep
!docs/research/real-csv/README.md

# Claude Code sandbox の組込み protected paths 保護（Layer 4）が bubblewrap で
# /dev/null を mount-mask する結果、character special file として git status に
# untracked で出現するもの。実ファイルではなくセッション外では不可視で、git は
# commit 対象にもしないが、毎セッションの git status ノイズを抑えるため明示 ignore。
# 参照: https://code.claude.com/docs/en/permission-modes#protected-paths
# 判断軸: memory/sandbox-protected-paths-gitignore-strategy.md
# Layer 4 の詳細: memory/sandbox-architecture-2026-04-19.md
.bash_profile
.bashrc
.profile
.zprofile
.zshrc
.gitconfig
.gitmodules
.ripgreprc
.mcp.json
.claude/agents
.claude/launch.json
.claude/routines
.claude/scheduled_tasks.json
.claude/workflows
# 以下は既存の .idea/ .vscode/* パターン（ディレクトリ内容マッチ）では
# character special file 形式の mount にヒットしないため、ファイル名形式で重複追加
.idea
.vscode
