# ============================================================================
# .env.example — 環境変数テンプレート (git 管理、全環境共通の変数一覧)
# ============================================================================
#
# WARNING: VITE_ prefix 変数はクライアントサイド JS バンドルに平文で埋め込まれ、
# 公開情報として扱われる。Tauri デスクトップ配布 binary は逆アセンブル可能なため、
# フロントエンド側に真の秘密は原理的に置けない。
# 秘密情報 (KEY / TOKEN / SECRET / PASSWORD 等) は絶対に書かないこと。
# 秘密が必要になった場合は Rust 側 OS keychain (keyring crate) 経由で扱う。
# 詳細: docs/UI_TECH_STACK.md §6.9 環境変数設計
#
# 環境別デフォルト (git 管理):
# - 開発:   .env.development (VITE_DEBUG=true)
# - テスト: .env.test (両方 false)
# - 本番:   .env.production (両方 false、CI static check で強制)
#
# 個人機ローカル上書き (gitignore 対象):
# - .env / .env.local / .env.*.local
# ============================================================================

# devtools / TanStack Query devtools / 詳細 console ログを有効化
# 値は 'true' / 'false' の文字列。src/lib/env.ts で厳格 equality 評価
VITE_DEBUG=

# backend IPC を mock 実装に差し替え (将来の UI-09a/b 等で実測値なし開発用)
VITE_MOCK_MODE=

# NOTE: VITE_APP_VERSION は package.json から vite.config.ts の define で注入
# するため、env ファイルには書かない
