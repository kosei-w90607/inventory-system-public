{
  "name": "inventory-system-tauri-scaffold",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run generate:routes && vite",
    "build": "vite build",
    "generate:routes": "tsr generate",
    "pretypecheck": "npm run generate:routes",
    "typecheck": "tsc --noEmit",
    "prelint": "npm run generate:routes",
    "lint": "eslint .",
    "prelint:fix": "npm run generate:routes",
    "lint:fix": "eslint . --fix",
    "pretest": "npm run generate:routes",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "tauri": "tauri",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yaml,yml}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-cli": "^1.166.33",
    "@tanstack/router-plugin": "^1.167.22",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.6",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.3.6",
    "vitest": "4.1.5"
  }
}
